# ── AI APIs ───────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Vector store ──────────────────────────────────────────────────────────────
PINECONE_API_KEY=...
PINECONE_INDEX_NAME=optum-schema

# ── SQL Server ────────────────────────────────────────────────────────────────
SQLSERVER_CONN_STR=DRIVER={ODBC Driver 18 for SQL Server};SERVER=your-server;DATABASE=OptumDW;UID=readonly_user;PWD=...

# ── Snowflake ─────────────────────────────────────────────────────────────────
SNOWFLAKE_ACCOUNT=your-account.us-east-1
SNOWFLAKE_USER=readonly_user
SNOWFLAKE_PASSWORD=...
SNOWFLAKE_DATABASE=OPTUM_DW
SNOWFLAKE_WAREHOUSE=ANALYTICS_WH
SNOWFLAKE_SCHEMA=PUBLIC

# ── App config ────────────────────────────────────────────────────────────────
# Options: sqlserver | snowflake
DB_DIALECT=sqlserver
